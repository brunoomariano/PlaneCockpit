{
  "name": "plc-cli",
  "version": "0.1.0-beta.1",
  "description": "CLI and TUI for Plane (Cloud and self-hosted), inspired by gh and gh dash.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "plc": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "build": "pnpm run gen:schema && tsup",
    "gen:schema": "tsx scripts/gen-schema.ts",
    "schema:check": "tsx scripts/gen-schema.ts --check",
    "dev": "tsx src/cli.ts",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "audit": "pnpm audit --prod --audit-level high",
    "deadcode": "knip --include files,dependencies",
    "deadcode:strict": "knip",
    "quality": "pnpm run lint && pnpm run deadcode:strict",
    "ci": "pnpm run fmt:check && pnpm run lint && pnpm run typecheck && pnpm run test:cov && pnpm run deadcode:strict && pnpm run audit && pnpm run schema:check && pnpm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.0",
    "better-sqlite3": "^12.10.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ink": "^7.0.4",
    "ioredis": "^5.11.0",
    "marked": "^18.0.4",
    "open": "^11.0.0",
    "react": "^19.2.6",
    "turndown": "^7.2.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "ink-testing-library": "^4.0.0",
    "knip": "^6.14.2",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
