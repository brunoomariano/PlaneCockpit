{
  "name": "plane-cli",
  "version": "0.1.0-beta.1",
  "description": "CLI and TUI for Plane (Cloud and self-hosted), inspired by gh and gh dash.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "plane": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "ci": "pnpm run fmt:check && pnpm run lint && pnpm run typecheck && pnpm run test:cov && pnpm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.0",
    "@makeplane/plane-node-sdk": "^0.2.11",
    "better-sqlite3": "^12.10.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ink": "^7.0.4",
    "ioredis": "^5.11.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "open": "^11.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.6",
    "turndown": "^7.2.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
