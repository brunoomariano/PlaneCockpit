{
  "$id": "https://github.com/dlvhdr/plane-cockpit/schema/config.schema.json",
  "title": "Plane Cockpit config",
  "description": "Configuration for the Plane Cockpit CLI/TUI (~/.config/plane-cli/config.yaml).",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "active_profile": {
      "type": "string",
      "minLength": 1
    },
    "profiles": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "server": {
            "type": "object",
            "properties": {
              "base_url": {
                "type": "string",
                "format": "uri"
              },
              "workspace_slug": {
                "type": "string",
                "minLength": 1
              },
              "timeout_ms": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "headers": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "tls": {
                "type": "object",
                "properties": {
                  "reject_unauthorized": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "base_url",
              "workspace_slug"
            ],
            "additionalProperties": false
          },
          "auth": {
            "type": "object",
            "properties": {
              "api_key": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "defaults": {
            "type": "object",
            "properties": {
              "projects": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "auto_refresh_seconds": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              }
            },
            "additionalProperties": false
          },
          "cache": {
            "type": "object",
            "properties": {
              "provider": {
                "type": "string",
                "enum": [
                  "memory",
                  "sqlite",
                  "redis",
                  "noop"
                ]
              },
              "ttl": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "sqlite_path": {
                "type": "string"
              },
              "redis": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "minLength": 1
                  },
                  "key_prefix": {
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "provider"
            ],
            "additionalProperties": false
          },
          "views": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "projects": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "filters": {
                  "type": "object",
                  "properties": {
                    "assignee": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        }
                      ]
                    },
                    "state_group": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": [
                          "backlog",
                          "unstarted",
                          "started",
                          "completed",
                          "cancelled"
                        ]
                      }
                    },
                    "labels": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "priority": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": [
                          "urgent",
                          "high",
                          "medium",
                          "low",
                          "none"
                        ]
                      }
                    },
                    "cycle": {
                      "type": "string"
                    },
                    "module": {
                      "type": "string"
                    },
                    "state_search": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "project_state_search": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string",
                            "minLength": 1
                          },
                          "state_search": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "minLength": 1
                            }
                          }
                        },
                        "required": [
                          "name",
                          "state_search"
                        ],
                        "additionalProperties": false
                      }
                    }
                  },
                  "additionalProperties": false
                },
                "sort": {
                  "type": "string",
                  "enum": [
                    "priority",
                    "updated_at",
                    "created_at",
                    "name"
                  ]
                },
                "query_limit": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "required": [
                "name"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "server"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "active_profile",
    "profiles"
  ],
  "additionalProperties": false
}
